generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id        String    @id
  createdAt DateTime  @default(now())
  posts     Post[]
  pdcaLogs  PdcaLog[]
}

model Post {
  id          String    @id @default(cuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  content     String
  amazonUrl   String?
  status      String    @default("pending") // pending | posted | failed
  scheduledAt DateTime
  postedAt    DateTime?
  xPostId     String?
  createdAt   DateTime  @default(now())
}

model PdcaLog {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  date      DateTime
  analysis  String
  createdAt DateTime @default(now())
}
